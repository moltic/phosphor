{
  "manifest_version": 3,
  "name": "Phosphor — CRT Terminal New Tab",
  "version": "1.0.0",
  "description": "A retro phosphor terminal interface for your New Tab page.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "phos.png",
    "48": "phos.png",
    "128": "phos.png"
  },
  "permissions": [
    "storage",
    "bookmarks",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "add-current-tab-dial": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "Add current tab as a speed-dial tile in bbtab"
    }
  },
  "host_permissions": [
    "https://api.open-meteo.com/",
    "https://nominatim.openstreetmap.org/"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; font-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com;"
  }
}
